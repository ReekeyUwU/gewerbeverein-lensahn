NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

DATABASE_URL="mysql://gvl:gvl_password@localhost:3306/gewerbeverein_lensahn"

JWT_ACCESS_SECRET="change-me-access-secret"

# STORAGE_DRIVER=local (default, writes to UPLOAD_DIR, no extra services needed)
# STORAGE_DRIVER=s3 (for MinIO/S3/R2 - fills in the S3_* vars below)
STORAGE_DRIVER=local
UPLOAD_DIR="./uploads"
UPLOAD_PUBLIC_URL="http://localhost:4000/uploads"

S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="minioadmin"
S3_SECRET_KEY="minioadmin"
S3_BUCKET="gewerbeverein-lensahn"
S3_PUBLIC_URL="http://localhost:9000/gewerbeverein-lensahn"

SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Gewerbeverein Lensahn <no-reply@gewerbeverein-lensahn.de>"
